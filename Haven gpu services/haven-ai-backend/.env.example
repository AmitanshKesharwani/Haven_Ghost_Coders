# "cpu" for local dev, "cuda" once deployed on the AMD MI300X droplet
HAVEN_DEVICE=cpu

WHISPER_MODEL_CPU=small
WHISPER_MODEL_GPU=openai/whisper-large-v3
WHISPER_COMPUTE_TYPE=int8

CLASSIFIER_MODEL_ID=sentinet/suicidality
CLASSIFIER_RISK_THRESHOLD=0.6

HAVEN_HOST=0.0.0.0
HAVEN_PORT=8000

# Comma-separated. Add your deployed frontend URL here once you have one.
HAVEN_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
